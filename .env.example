# Futu OpenD Connection
OPEND_IP=127.0.0.1
OPEND_PORT=11111
OPEND_ENCRYPT=false
# OPEND_RSA_KEY=

# Stock Group Filter (leave empty to use first group)
FUTU_GROUP_NAME=

# Monitoring Parameters
PRICE_CHANGE_THRESHOLD=2.0
ALERT_COOLDOWN_MINUTES=15
KLINE_REFRESH_INTERVAL=60000
MARKET_STATE_POLL_INTERVAL=30000

# MA Periods (comma-separated)
# Default: 5,13,30,55

# Reconnect Settings
RECONNECT_INITIAL_DELAY_MS=5000
RECONNECT_MAX_DELAY_MS=60000
RECONNECT_MULTIPLIER=2.0

# Email Notification
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_TO=recipient@example.com

# Docker-specific: use host.docker.internal to reach OpenD on host machine
# OPEND_IP=host.docker.internal
